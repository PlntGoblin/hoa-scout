# Copy to .env and fill in your keys. Never commit .env.

# MapTiler — basemap tiles + geocoding (free tier: https://cloud.maptiler.com/)
VITE_MAPTILER_KEY=your_maptiler_key_here

# RentCast — AVM + rent estimates, optional (free tier 50 calls/month: https://www.rentcast.io/)
VITE_RENTCAST_KEY=your_rentcast_key_here

# Login gate — shared password for all users
VITE_APP_PASSWORD=your_password_here
